PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info
REDIS_URL=redis://localhost:6379
REDIS_RETRY_COOLDOWN_MS=30000
AUTH_CACHE_TTL_SECONDS=30
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=1h

# Neon pooled connection for application queries (hostname contains -pooler)
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-POOLER-HOST/neondb?sslmode=require

# Neon direct connection for Prisma migrations and schema commands
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-NEON-DIRECT-HOST/neondb?sslmode=require

# Optional disposable, migrated PostgreSQL database used by `npm run test:integration`
TEST_DATABASE_URL=postgresql://USER:PASSWORD@YOUR-TEST-NEON-HOST/neondb?sslmode=require

# Initial administrator created by `npm run db:seed`
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-at-least-12-characters
SEED_SUPER_ADMIN_NAME=System Administrator
SEED_SUPER_ADMIN_EMPLOYEE_ID=ADMIN-001

# Shared password for local/demo employees created by `npm run db:seed:demo`
DEMO_EMPLOYEE_PASSWORD=replace-with-at-least-12-characters
