PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Neon pooled connection for application queries (hostname contains -pooler)
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-POOLER-HOST/neondb?sslmode=require

# Neon direct connection for Prisma migrations and schema commands
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-NEON-DIRECT-HOST/neondb?sslmode=require

# Initial administrator created by `npm run db:seed`
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-at-least-12-characters
SEED_SUPER_ADMIN_NAME=System Administrator
SEED_SUPER_ADMIN_EMPLOYEE_ID=ADMIN-001
